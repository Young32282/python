#include <stdio.h>

double totamt(int quarters, int dimes, int nickels, int pennies) {
    const double ejwf = 0.25;
    const double yj = 0.10;
    const double wf = 0.05;
    const double yf = 0.01;

    // 计算总金额
    double total_amount = (quarters * ejwf) + (dimes * yj) +
                          (nickels * wf) + (pennies * yf);
    
    return total_amount;
}

int main() {
    int quarters, dimes, nickels, pennies;
    
    scanf("%d %d %d %d", &quarters, &dimes, &nickels, &pennies);
    
    printf("%.2f\n", totamt(quarters, dimes, nickels, pennies));
    
    return 0;
}