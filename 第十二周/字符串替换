#include <stdio.h>
void replace_char(char*str,char c,char r){
    int i =0;
    
    while(str[i]){
        if (str[i] == c || str[i] == c + ('a' - 'A') || str[i] == c - ('a' - 'A')){
            str[i]= r;
        }
        i++;
    }

}
int main(){
    char str[100];
    char c;
    char r;
    scanf("%s",str);//%s是读取字符串，读取单个字母要用%c
    scanf(" %c",&c);
    scanf(" %c",&r);
    replace_char(str,c,r);
    printf("%s\n",str);
    return 0;
}

#include <stdio.h>  

void replace_char(char *str, char c, char r) {  
    int i = 0; // 初始化一个索引用于遍历字符串  
    
    // 遍历字符串，直到遇到字符串结束符（null字符）  
    while (str[i]) {  
        // 如果当前字符等于c，则替换为r  
        if (str[i] == c) {  
            str[i] = r;  
        }  
        i++; // 移动到下一个字符  
    }  
}  

int main() {  
    char str[100]; // 定义一个字符数组来存储原字符串  
    char c;       // 定义一个字符变量来存储要替换的字符  
    char r;       // 定义一个字符变量来存储新的字符  

    // 逐行读取输入  
    printf("请输入原字符串：");  
    scanf("%s", str); // 读取字符串  

    printf("请输入要替换的字符：");  
    scanf(" %c", &c); // 读取要替换的字符（前面加空格以跳过换行符）  

    printf("请输入新字符：");  
    scanf(" %c", &r); // 读取新字符（同样前面加空格）  

    replace_char(str, c, r); // 调用字符替换函数  
    printf("替换后的字符串：%s\n", str); // 输出结果  

    return 0; // 程序结束  
} 