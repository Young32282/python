#include <stdio.h>
#include <string.h>

void delChar(char *str, int count, int start) {
    int len = strlen(str);
    if (start < 0 || start >= len || count < 0 || start + count > len) {
        // 参数无效，直接返回
        return;
    }
    // 移动字符以覆盖要删除的部分
    memmove(str + start, str + start + count, len - start - count + 1);
}

int main() {
    char str[100]; // 假设字符串不会超过99个字符
    int count, start;

    // 读取输入
    fgets(str, sizeof(str), stdin); // 读取字符串，包括空格
    str[strcspn(str, "\n")] = 0; // 去除字符串末尾的换行符
    scanf("%d", &count); // 读取要删除的字符数目
    scanf("%d", &start); // 读取被删除字符的起始位置

    // 调用函数删除字符
    delChar(str, count, start);

    // 输出新的字符串
    printf("%s\n", str);

    return 0;
}