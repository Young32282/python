int*create_array(int n,int initial_value){
    if(n==0){
        return NULL;
    }
    int*arr=(int *)malloc(n*sizeof(int));
    for (int i=0;i<n;i++){
        arr[i]=initial_value;
    }
    for (int i = 0; i < n; i++) {  
        printf("%d", arr[i]);  
        if (i < n - 1) {  
            printf(" ");  
        }  
    }  
    return arr;
}



#include <stdio.h>  
#include <stdlib.h>   
int* create_array(int n, int initial_value);  

int main() {  
    int n, initial_value;     
    scanf("%d", &n);  
    scanf("%d", &initial_value);  
    int *array = create_array(n, initial_value);  
    if (array == NULL) {  
        printf("Memory allocation failed\n");  
        return 1; // 返回错误代码  
    }  
    // 输出数组中的所有元素  
    for (int i = 0; i < n; i++) {  
        printf("%d", array[i]);  
        if (i < n - 1) { // 在元素之间添加空格  
            printf(" ");  
        }  
    }  
    printf("\n");  
    // 释放动态分配的内存  
    free(array);   
    return 0;  
}  

// 实现 create_array 函数  
int* create_array(int n, int initial_value) {  
    int *array = (int *)malloc(n * sizeof(int));  
    if (array == NULL) {  
        return NULL; 
    }  
    for (int i = 0; i < n; i++) {  
        array[i] = initial_value;  
    }  
    
    return array; 
} 