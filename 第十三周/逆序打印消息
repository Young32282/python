#include<stdio.h>
#include<string.h>
void read_and_reverse(const char* str,char *output);
int main(){
    char str[100];
    scanf("%s",str);
    char output[100];
    read_and_reverse(str,output);
    printf("%s\n",output);
    return 0;
}
void read_and_reverse(const char* str,char *output){
    int len =strlen(str);    
    int j=0;
    for (int i=len-1;i>=0;i--){
        output[j++]=str[i];
    }
    output[j]='\0';
}


#include <stdio.h>
#include <string.h>
 
void read_and_reverse(char* output) {
    char c;
    int index = 0;
    // 读取字符直到遇到换行符或数组满
    while ((c = getchar()) != '\n' && index < 99) {
        output[index++] = c;
    }
    // 添加字符串结束符
    output[index] = '\0';
 
    // 逆序存储到同一个数组的开始位置
    int len = strlen(output);
    for (int i = 0; i < len / 2; i++) {
        char temp = output[i];
        output[i] = output[len - i - 1];
        output[len - i - 1] = temp;
    }
}
 
int main() {
    char output[100];
    printf("请输入一条消息：");
    read_and_reverse(output);
    printf("逆序后的消息：%s\n", output);
    return 0;
}


#include <stdio.h>
#include <stdlib.h>
 
#define MAX_LENGTH 1000  // 假设最大长度为1000
 
void read_and_reverse() {
    char buffer[MAX_LENGTH];
    int index = 0;
    char ch;
 
    // 读取字符直到遇到换行符或数组满
    while ((ch = getchar()) != '\n' && index < MAX_LENGTH - 1) {
        buffer[index++] = ch;
    }
    buffer[index] = '\0';
 
    for (int i = index - 1; i >= 0; i--) {
        putchar(buffer[i]);
    }
    putchar('\n');  // 输出换行符以美化输出
}
 
int main() {
    read_and_reverse();
    return 0;
}
