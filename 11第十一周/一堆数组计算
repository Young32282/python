#include <stdio.h>
int main(){
    float price[10],quantity[10],amount[10];
    for (int i=0;i<10;i++){
        scanf("%f %f",&price[i],&quantity[i]);
        amount[i]=price[i]*quantity[i];
    }
    for (int i=0;i<10;i++){
        printf("%.2f %.2f %.2f\n",price[i],quantity[i],amount[i]);
    }
    return 0;
}