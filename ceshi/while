#include <stdio.h>
int main(){
  int i=0;
  while (i<100){
    if (i/7==0 || i%10==7 || i/10==7){
      printf ("含7\n");
    }
    else {
        printf ("%d\n",i);
    }
    i++;
  }
   return 0;
}
