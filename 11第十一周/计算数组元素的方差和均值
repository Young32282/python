#include <stdio.h>  

void statistics(double v[], int length, double results[]) {  
    double sum = 0.0;  
    double sum_of_squares = 0.0;  

    for (int i = 0; i < length; i++) {  
        sum += v[i]; // 计算总和  
    }  

    double mean = sum / length; // 计算均值  
    results[0] = mean; // 将均值存入 results[0]  

    for (int i = 0; i < length; i++) {  
        sum_of_squares += (v[i] - mean) * (v[i] - mean); // 计算偏差平方和  
    }  

    double variance = sum_of_squares / length; // 计算方差  
    results[1] = variance; // 将方差存入 results[1]  
}  

int main() {  
    double v[5]; // 长度为5的数组  
    double results[2]; // 存放结果的数组  

    // 输入5个元素  
    for (int i = 0; i < 5; i++) {  
        scanf("%lf", &v[i]); // 输入每个元素  
    }  

    statistics(v, 5, results); // 计算均值和方差  

    // 输出均值和方差，保留2位小数  
    printf("%.2f %.2f\n", results[0], results[1]);  

    return 0;  
}  