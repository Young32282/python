#include <stdio.h>  

double average(double v[], int length) {  
    double sum = 0; // 正确初始化 sum  
    for (int i = 0; i < length; i++) {  
        sum += v[i]; // 正确累加 v[i] 到 sum  
    }  
    double ave = sum / length; // 计算平均值  
    return ave;  
}  

int main() {  
    double v[5];  
    int length = sizeof(v) / sizeof(v[0]);  
    for (int i = 0; i < length; i++) {  
        scanf("%lf", &v[i]); // 使用 %lf 读取 double 类型  
    }  
    
    printf("%.2f\n", average(v, length)); // 传递整个数组 v  
    return 0;  
}  
