#include <stdio.h>
 
// 函数声明
void date(int yyyymmdd, int *year, int *month, int *day);
 
int main() {
    int yyyymmdd, year, month, day;
 
    // 读取输入
    printf("请输入yyyymmdd形式的整数: ");
    scanf("%d", &yyyymmdd);
 
    // 调用函数进行转换
    date(yyyymmdd, &year, &month, &day);
 
    // 输出结果
    printf("%d %d %d\n", year, month, day);
 
    return 0;
}
 
// 函数定义
void date(int yyyymmdd, int *year, int *month, int *day) {
    // 提取年份
    *year = yyyymmdd / 10000;
 
    // 提取月份
    *month = (yyyymmdd / 100) % 100;
 
    // 提取日期
    *day = yyyymmdd % 100;
}