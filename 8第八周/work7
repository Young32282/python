#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int dice() {
    srand(1024);

    int dice1 = rand() % 6 + 1;
    int dice2 = rand() % 6 + 1; 
    int sum = dice1 + dice2;    

    if (sum == 7 || sum == 11) {
        return 1;
    } else {
        return 0;
    }
}

int main() {
    printf("%d\n", dice());
    return 0;
}