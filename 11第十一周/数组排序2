#include<stdio.h>
#include <stdlib.h>  

double generateRandomNumber() {  
    return (double)rand() / (double)RAND_MAX; // 生成[0,1)之间的双精度浮点数  
}  

int main() {  
    srand(1024); // 设置随机数种子为1024  
    double raw[10]; // 存储随机数的数组  
    double sort[10]; // 用于存放排序后的数组  

    // 生成10个随机数并存储到raw数组  
    for (int i = 0; i < 10; i++) {  
        raw[i] = generateRandomNumber();  
    }  

    // 从raw数组中找到最小值并存入sort数组  
    for (int i = 0; i < 10; i++) {  
        double minValue = 2.0; // 初始化最小值  
        int minIndex = -1; // 记录最小值的索引  

        // 遍历raw数组寻找当前的最小值  
        for (int j = 0; j < 10; j++) {  
            if (raw[j] < minValue) {  
                minValue = raw[j];  
                minIndex = j; // 获取最小值的索引  
            }  
        }  

        // 将找到的最小值存入sort数组，并在raw中将其设置为一个较大的数，以防重复选择  
        sort[i] = minValue;  
        raw[minIndex] = 2.0; // 将该最小值设置为一个大于所有值的数（如2.0），避免下次再选中  
    }  

    // 打印sort数组，保留小数点后4位  
    for (int i = 0; i < 10; i++) {  
        printf("%.4f", sort[i]);  
        if (i < 9) {  
            printf(" "); // 在每两个数字之间用空格分隔  
        }  
    }  
    
    printf("\n"); // 换行  
    
    return 0;  
}  