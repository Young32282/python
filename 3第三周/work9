#include <stdio.h>  
#include <math.h>  

int main() {  
    // 定义初始存款和年利率  
    double principal = 1000.0; // 初始存款  
    double interest_rate = 0.0125; // 年利率 1.25%  
    int N; // 用户输入的年数  

    // 提示用户输入年数  
    printf("请输入存款年数 N: ");  
    scanf("%d", &N);  

    // 计算 N 年后的存款数  
    double amount = principal * pow(1 + interest_rate, N);  

    // 输出结果，保留2位小数  
    printf("%.2f\n", amount);  

    return 0;  
}