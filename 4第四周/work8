#include <stdio.h>  

void convert_to_12_hour_format(const char *time_24) {  
    int hour, minute;  
    
    sscanf(time_24, "%d:%d", &hour, &minute);  
    

    int hour_12;  
    char period[3];  
    
    if (hour == 0) {  
        hour_12 = 12;  
        sprintf(period, "AM");  
    } else if (hour < 12) {  
        hour_12 = hour;  
        sprintf(period, "AM");  
    } else if (hour == 12) {  
        hour_12 = 12;  
        sprintf(period, "PM");  
    } else {  
        hour_12 = hour - 12;  
        sprintf(period, "PM");  
    }  
    
    printf("%d:%02d %s\n", hour_12, minute, period);  
}  

int main() {  
    char time_24[6];  
    
    printf("请输入24小时制的时间 (格式：HH:MM): ");  
    scanf("%5s", time_24);  

    convert_to_12_hour_format(time_24);  
    
    return 0;  
}  