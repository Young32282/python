#include <stdio.h>  
#include <string.h>  

void get_extension(const char* file_name, char* extension) {  
    // 查找最后一个 '.' 的位置  
    const char* dot = strrchr(file_name, '.');  
    
    // 如果找到了 '.' 并且它不是文件名的开头位置  
    if (dot && dot != file_name) {  
        // 从 '.' 的下一个字符开始复制到扩展名  
        strcpy(extension, dot + 1);  
    } else {  
        // 如果没有扩展名，将 extension 设置为空字符串  
        strcpy(extension, "");  
    }  
}  

int main() {  
    char file_name[100];   // 用于存储文件名  
    char extension[10];    // 用于存储扩展名，假设扩展名不会超过9个字符+1个结束符  

    // 接收用户输入文件名  
    printf("请输入文件名: ");  
    scanf("%s", file_name);  
    
    // 调用函数获取文件扩展名  
    get_extension(file_name, extension);  
    
    // 输出扩展名  
    printf("文件扩展名: %s\n", extension);  
    
    return 0;  
}  